APP_NAME=Academic Integrity & Automated Lab Evaluation System
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aiales
DATABASE_URL=sqlite:///database/aiales.db
AUTO_CREATE_TABLES=true

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

LOG_LEVEL=INFO
FRONTEND_API_BASE_URL=http://127.0.0.1:8000/api/v1
MAX_UPLOAD_MB=25
STORAGE_BACKEND=local
SEMANTIC_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
PLAGIARISM_THRESHOLD_LOW=0.35
PLAGIARISM_THRESHOLD_MEDIUM=0.60
PLAGIARISM_THRESHOLD_HIGH=0.80
SEMANTIC_SIMILARITY_CUTOFF=0.45
SECTION_HEADING_SIMILARITY_THRESHOLD=0.78
BLANK_IMAGE_VARIANCE_THRESHOLD=12.0
SCREENSHOT_DUPLICATE_SIMILARITY_THRESHOLD=0.96
MARKS_COMPLETENESS_WEIGHT=25
MARKS_EXECUTION_WEIGHT=25
MARKS_THEORY_WEIGHT=15
MARKS_RELEVANCE_WEIGHT=15
MARKS_SCREENSHOT_WEIGHT=10
MARKS_PLAGIARISM_PENALTY_WEIGHT=10
